<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_header_bottom_rounded"
        android:elevation="6dp"
        android:orientation="vertical"
        android:paddingStart="22dp"
        android:paddingTop="48dp"
        android:paddingEnd="22dp"
        android:paddingBottom="24dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/routeBackButton"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:backgroundTint="#26FFFFFF"
            android:minWidth="0dp"
            android:paddingStart="14dp"
            android:paddingEnd="16dp"
            android:text="← Назад"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="13sp"
            android:textStyle="bold"
            app:cornerRadius="18dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Маршрут"
            android:textColor="@color/white"
            android:textSize="30sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/routeSubtitleTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Выберите задачи, дальше откроем Google Maps"
            android:textColor="#E6FFF0"
            android:textSize="14sp" />
    </LinearLayout>

    <ProgressBar
        android:id="@+id/routeProgressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:visibility="gone" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="28dp"
                app:cardElevation="3dp"
                app:strokeColor="#E2ECE7"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Задачи"
                                android:textColor="@color/text_dark"
                                android:textSize="19sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/selectedCountTextView"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="3dp"
                                android:text="0 из 0"
                                android:textColor="@color/text_gray"
                                android:textSize="13sp" />
                        </LinearLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/selectAllButton"
                            android:layout_width="wrap_content"
                            android:layout_height="42dp"
                            android:backgroundTint="#E7EFEA"
                            android:minWidth="0dp"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:text="Все"
                            android:textAllCaps="false"
                            android:textColor="@color/text_dark"
                            android:textSize="13sp"
                            app:cornerRadius="16dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/taskSelectionContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:orientation="vertical" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/optimizeRouteButton"
                            android:layout_width="0dp"
                            android:layout_height="50dp"
                            android:layout_marginEnd="8dp"
                            android:layout_weight="1"
                            android:backgroundTint="@color/green_main"
                            android:text="Перестроить"
                            android:textAllCaps="false"
                            android:textColor="@color/white"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            app:cornerRadius="17dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/refreshRouteButton"
                            android:layout_width="116dp"
                            android:layout_height="50dp"
                            android:backgroundTint="#E7EFEA"
                            android:text="Обновить"
                            android:textAllCaps="false"
                            android:textColor="@color/text_dark"
                            android:textSize="13sp"
                            app:cornerRadius="17dp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/routeSummaryTextView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Загрузка задач..."
                        android:textColor="@color/text_gray"
                        android:textSize="13sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Порядок обхода"
                android:textColor="@color/text_dark"
                android:textSize="20sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/routeStopsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="vertical" />
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#F7FBF8"
        android:paddingStart="16dp"
        android:paddingTop="12dp"
        android:paddingEnd="16dp"
        android:paddingBottom="16dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/openRouteButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:backgroundTint="#111827"
            android:text="Открыть маршрут в Google Maps"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:textStyle="bold"
            app:cornerRadius="18dp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/bottomNavContainer"
        android:layout_width="match_parent"
        android:layout_height="78dp"
        android:background="@drawable/bg_bottom_nav"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingStart="10dp"
        android:paddingEnd="10dp">

        <TextView android:id="@+id/navHomeTextView" style="@style/BottomNavItem" android:text="Главная" />
        <TextView android:id="@+id/navTasksTextView" style="@style/BottomNavItem" android:text="Задачи" />
        <TextView android:id="@+id/navRouteTextView" style="@style/BottomNavItem" android:text="Маршрут" />
        <TextView android:id="@+id/navMapTextView" style="@style/BottomNavItem" android:text="Карта" />
        <TextView android:id="@+id/navProfileTextView" style="@style/BottomNavItem" android:text="Профиль" android:visibility="gone" />
    </LinearLayout>

</LinearLayout>
