<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_header_bottom_rounded"
        android:elevation="6dp"
        android:orientation="vertical"
        android:paddingStart="22dp"
        android:paddingTop="48dp"
        android:paddingEnd="22dp"
        android:paddingBottom="22dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/homeRoleTextView"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:text="Исполнитель"
                android:textColor="#DFFFEA"
                android:textSize="13sp"
                android:textStyle="bold" />

            <FrameLayout
                android:id="@+id/profileAvatarContainer"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="@drawable/bg_home_avatar"
                android:foreground="?attr/selectableItemBackgroundBorderless"
                android:visibility="gone">

                <TextView
                    android:id="@+id/homeAvatarInitialsTextView"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:layout_gravity="center"
                    android:gravity="center"
                    android:text="С"
                    android:textColor="@color/green_dark"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <com.example.cleancity.ui.CircleImageView
                    android:id="@+id/homeAvatarImageView"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:layout_gravity="center"
                    android:visibility="gone" />
            </FrameLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/logoutButton"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:backgroundTint="#E9F8EF"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:minWidth="0dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:text="Выйти"
                android:textAllCaps="false"
                android:textColor="@color/green_dark"
                android:textSize="13sp"
                android:textStyle="bold"
                app:cornerRadius="22dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/homeTitleTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Рабочий день"
            android:textColor="@color/white"
            android:textSize="30sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/homeSubtitleTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:lineSpacingExtra="2dp"
            android:text="Рабочий кабинет"
            android:textColor="#E6FFF0"
            android:textSize="14sp" />

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingTop="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="22dp">

            <LinearLayout
                android:id="@+id/workerDashboardContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:orientation="vertical"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="92dp"
                        android:layout_marginEnd="7dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_home_stat_tile"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            android:id="@+id/homeActiveCountTextView"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/text_dark"
                            android:textSize="26sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Активные"
                            android:textColor="@color/text_gray"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="92dp"
                        android:layout_marginStart="7dp"
                        android:layout_marginEnd="7dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_home_stat_tile"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            android:id="@+id/homeWorkCountTextView"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/text_dark"
                            android:textSize="26sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="В работе"
                            android:textColor="@color/text_gray"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="92dp"
                        android:layout_marginStart="7dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_home_stat_tile"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            android:id="@+id/homeDoneCountTextView"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/text_dark"
                            android:textSize="26sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Выполнено"
                            android:textColor="@color/text_gray"
                            android:textSize="12sp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Summary card — for workers -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/summaryCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="26dp"
                    app:cardElevation="3dp"
                    app:strokeColor="#E2ECE7"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Сводка"
                            android:textColor="@color/text_dark"
                            android:textSize="19sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/homeNextStepTextView"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:lineSpacingExtra="2dp"
                            android:text="Загрузим задачи после входа"
                            android:textColor="@color/text_gray"
                            android:textSize="14sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Points card — for residents -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/pointsCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:visibility="gone"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="26dp"
                    app:cardElevation="3dp"
                    app:strokeColor="#E2ECE7"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Мои баллы"
                            android:textColor="@color/text_dark"
                            android:textSize="19sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/pointsCountTextView"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:lineSpacingExtra="0dp"
                            android:text="0"
                            android:textColor="@color/green_dark"
                            android:textSize="52sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:lineSpacingExtra="2dp"
                            android:text="Баллы начисляются за активность и выполненные обращения"
                            android:textColor="@color/text_gray"
                            android:textSize="13sp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/rewardButton"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:layout_marginTop="18dp"
                            android:backgroundTint="@color/green_dark"
                            android:text="Получить вознаграждение"
                            android:textAllCaps="false"
                            android:textColor="@color/white"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            app:cornerRadius="24dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/newsButton"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:layout_marginTop="10dp"
                            android:backgroundTint="#DFF5E6"
                            android:text="Новости"
                            android:textAllCaps="false"
                            android:textColor="@color/green_dark"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            app:cornerRadius="24dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <TextView
                android:id="@+id/homeSectionTitleTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Разделы"
                android:textColor="@color/text_dark"
                android:textSize="20sp"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/primaryCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:foreground="?attr/selectableItemBackground"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="28dp"
                app:cardElevation="3dp"
                app:strokeColor="#E2ECE7"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="18dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/primaryTitleTextView"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Мои задачи"
                            android:textColor="@color/text_dark"
                            android:textSize="19sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/primaryDescriptionTextView"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:lineSpacingExtra="2dp"
                            android:text="Принять и закрыть обращение"
                            android:textColor="@color/text_gray"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/primaryActionTextView"
                        android:layout_width="92dp"
                        android:layout_height="42dp"
                        android:background="@drawable/bg_home_action_green"
                        android:gravity="center"
                        android:text="Открыть"
                        android:textColor="@color/white"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/secondaryCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:foreground="?attr/selectableItemBackground"
                app:cardBackgroundColor="#F7FFFA"
                app:cardCornerRadius="28dp"
                app:cardElevation="2dp"
                app:strokeColor="#CFE8DA"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="18dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/secondaryTitleTextView"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Маршрут"
                            android:textColor="@color/text_dark"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/secondaryDescriptionTextView"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:lineSpacingExtra="2dp"
                            android:text="Порядок обхода задач"
                            android:textColor="@color/text_gray"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/secondaryActionTextView"
                        android:layout_width="92dp"
                        android:layout_height="42dp"
                        android:background="@drawable/bg_home_action_light"
                        android:gravity="center"
                        android:text="Построить"
                        android:textColor="@color/green_dark"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/tertiaryCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="24dp"
                android:foreground="?attr/selectableItemBackground"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="28dp"
                app:cardElevation="2dp"
                app:strokeColor="#E2ECE7"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="18dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tertiaryTitleTextView"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Карта обращений"
                            android:textColor="@color/text_dark"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tertiaryDescriptionTextView"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:lineSpacingExtra="2dp"
                            android:text="Все точки на карте"
                            android:textColor="@color/text_gray"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tertiaryActionTextView"
                        android:layout_width="92dp"
                        android:layout_height="42dp"
                        android:background="@drawable/bg_home_action_dark"
                        android:gravity="center"
                        android:text="Смотреть"
                        android:textColor="@color/white"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/bottomNavContainer"
        android:layout_width="match_parent"
        android:layout_height="78dp"
        android:background="@drawable/bg_bottom_nav"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/navHomeTextView"
            style="@style/BottomNavItem"
            android:text="Главная" />

        <TextView
            android:id="@+id/navTasksTextView"
            style="@style/BottomNavItem"
            android:text="Задачи" />

        <TextView
            android:id="@+id/navRouteTextView"
            style="@style/BottomNavItem"
            android:text="Маршрут" />

        <TextView
            android:id="@+id/navMapTextView"
            style="@style/BottomNavItem"
            android:text="Карта" />

        <TextView
            android:id="@+id/navProfileTextView"
            style="@style/BottomNavItem"
            android:visibility="gone"
            android:text="Профиль" />
    </LinearLayout>
</LinearLayout>
